<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_gradient_primary"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingTop="14dp"
        android:paddingBottom="14dp"
        android:paddingHorizontal="16dp">

        <ImageButton
            android:id="@+id/btn_voltar"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@android:drawable/ic_media_previous"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="@color/white"
            android:contentDescription="Voltar"
            android:layout_marginEnd="10dp" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="UniPass"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/white" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Área do Participante"
                android:textSize="11sp"
                android:textColor="#99CCFF" />

        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🎟"
            android:textSize="22sp" />

    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="32dp">

            <!-- ── BLOCO 1 — Identificação ── -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="4dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="@color/surface">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="14dp">

                        <View
                            android:layout_width="4dp"
                            android:layout_height="22dp"
                            android:background="@color/primary"
                            android:layout_marginEnd="10dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🔍  Identificação"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:textColor="@color/text_primary" />

                    </LinearLayout>

                    <EditText
                        android:id="@+id/et_email"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Digite seu e-mail"
                        android:inputType="textEmailAddress"
                        android:padding="12dp"
                        android:background="@color/background"
                        android:textColorHint="@color/text_hint"
                        android:layout_marginBottom="12dp" />

                    <Button
                        android:id="@+id/btn_buscar"
                        android:layout_width="match_parent"
                        android:layout_height="46dp"
                        android:text="Entrar com e-mail"
                        android:textAllCaps="false"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:backgroundTint="@color/primary" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ── BLOCO 2 — Cadastro (gone by default) ── -->
            <androidx.cardview.widget.CardView
                android:id="@+id/layout_cadastro"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="12dp"
                android:visibility="gone"
                app:cardCornerRadius="14dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="#FFFBEB">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="8dp">

                        <View
                            android:layout_width="4dp"
                            android:layout_height="22dp"
                            android:background="@color/warning"
                            android:layout_marginEnd="10dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="👤  Primeiro acesso? Cadastre-se!"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:textColor="@color/warning" />

                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="E-mail não encontrado. Preencha seus dados para se cadastrar:"
                        android:textSize="13sp"
                        android:textColor="@color/text_secondary"
                        android:layout_marginBottom="12dp" />

                    <EditText
                        android:id="@+id/et_nome_cadastro"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Seu nome completo *"
                        android:inputType="textPersonName"
                        android:padding="12dp"
                        android:background="@color/background"
                        android:textColorHint="@color/text_hint"
                        android:layout_marginBottom="10dp" />

                    <EditText
                        android:id="@+id/et_telefone_cadastro"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Telefone (opcional)"
                        android:inputType="phone"
                        android:padding="12dp"
                        android:background="@color/background"
                        android:textColorHint="@color/text_hint"
                        android:layout_marginBottom="14dp" />

                    <Button
                        android:id="@+id/btn_cadastrar_se"
                        android:layout_width="match_parent"
                        android:layout_height="46dp"
                        android:text="Cadastrar-se"
                        android:textAllCaps="false"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:backgroundTint="@color/warning" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ── BLOCO 3 — Solicitar vaga (gone by default) ── -->
            <androidx.cardview.widget.CardView
                android:id="@+id/layout_solicitar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="12dp"
                android:visibility="gone"
                app:cardCornerRadius="14dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="@color/surface">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="14dp">

                        <View
                            android:layout_width="4dp"
                            android:layout_height="22dp"
                            android:background="@color/success"
                            android:layout_marginEnd="10dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🎟  Solicitar vaga em evento"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:textColor="@color/text_primary" />

                    </LinearLayout>

                    <Spinner
                        android:id="@+id/spinner_eventos"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp" />

                    <Button
                        android:id="@+id/btn_solicitar"
                        android:layout_width="match_parent"
                        android:layout_height="46dp"
                        android:text="Solicitar vaga"
                        android:textAllCaps="false"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:backgroundTint="@color/success" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ── BLOCO 4 — Minhas solicitações (gone by default) ── -->
            <LinearLayout
                android:id="@+id/layout_minhas_solicitacoes"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone"
                android:layout_marginTop="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="20dp"
                    android:layout_marginBottom="8dp">

                    <View
                        android:layout_width="4dp"
                        android:layout_height="20dp"
                        android:background="@color/warning"
                        android:layout_marginEnd="10dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📋  Minhas solicitações"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary" />

                </LinearLayout>

                <TextView
                    android:id="@+id/tv_sem_solicitacoes_p"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Nenhuma solicitação ainda."
                    android:textColor="@color/text_hint"
                    android:paddingHorizontal="20dp"
                    android:visibility="gone" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_minhas_solicitacoes"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false" />

            </LinearLayout>

            <!-- ── BLOCO 5 — Meus ingressos (gone by default) ── -->
            <LinearLayout
                android:id="@+id/layout_ingressos"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone"
                android:layout_marginTop="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="20dp"
                    android:layout_marginBottom="8dp">

                    <View
                        android:layout_width="4dp"
                        android:layout_height="20dp"
                        android:background="@color/primary"
                        android:layout_marginEnd="10dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🎫  Meus ingressos"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary" />

                </LinearLayout>

                <TextView
                    android:id="@+id/tv_sem_ingressos"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Nenhum ingresso aprovado ainda."
                    android:textColor="@color/text_hint"
                    android:gravity="center"
                    android:visibility="gone"
                    android:paddingVertical="16dp" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_meus_ingressos"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"
                    android:visibility="gone" />

            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</LinearLayout>
