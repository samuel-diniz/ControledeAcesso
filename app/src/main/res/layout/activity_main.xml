<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <!-- Hero Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_gradient_primary"
        android:paddingTop="48dp"
        android:paddingBottom="36dp"
        android:paddingHorizontal="28dp"
        android:gravity="center_horizontal">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🎫"
            android:textSize="48sp"
            android:layout_marginBottom="12dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="UniPass"
            android:textSize="36sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:letterSpacing="0.04" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Controle de acesso inteligente"
            android:textSize="14sp"
            android:textColor="#B3D4FF"
            android:layout_marginTop="6dp" />

    </LinearLayout>

    <!-- Cards Area -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Selecione seu perfil"
                android:textSize="14sp"
                android:textColor="@color/text_secondary"
                android:layout_marginBottom="20dp"
                android:layout_gravity="center_horizontal" />

            <!-- Card Organizador -->
            <androidx.cardview.widget.CardView
                android:id="@+id/card_organizador"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                android:foreground="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"
                app:cardCornerRadius="16dp"
                app:cardElevation="6dp"
                app:cardBackgroundColor="@color/primary">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="22dp"
                    android:gravity="center_vertical">

                    <LinearLayout
                        android:layout_width="52dp"
                        android:layout_height="52dp"
                        android:gravity="center"
                        android:background="#33FFFFFF"
                        android:layout_marginEnd="18dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🎯"
                            android:textSize="24sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Sou Organizador"
                            android:textSize="17sp"
                            android:textStyle="bold"
                            android:textColor="@color/white" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Gerenciar eventos, aprovar solicitações"
                            android:textSize="12sp"
                            android:textColor="#CCE0FF"
                            android:layout_marginTop="3dp" />

                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="›"
                        android:textSize="26sp"
                        android:textColor="#99FFFFFF" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Card Participante -->
            <androidx.cardview.widget.CardView
                android:id="@+id/card_participante"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                android:foreground="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"
                app:cardCornerRadius="16dp"
                app:cardElevation="6dp"
                app:cardBackgroundColor="#16A34A">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="22dp"
                    android:gravity="center_vertical">

                    <LinearLayout
                        android:layout_width="52dp"
                        android:layout_height="52dp"
                        android:gravity="center"
                        android:background="#33FFFFFF"
                        android:layout_marginEnd="18dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🎟"
                            android:textSize="24sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Sou Participante"
                            android:textSize="17sp"
                            android:textStyle="bold"
                            android:textColor="@color/white" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Ver meu ingresso e QR Code"
                            android:textSize="12sp"
                            android:textColor="#CCFAF0"
                            android:layout_marginTop="3dp" />

                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="›"
                        android:textSize="26sp"
                        android:textColor="#99FFFFFF" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Scanner Card -->
            <androidx.cardview.widget.CardView
                android:id="@+id/btn_scanner"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="28dp"
                android:foreground="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="#1E293B">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="20dp"
                    android:gravity="center_vertical">

                    <LinearLayout
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:gravity="center"
                        android:background="#33FFFFFF"
                        android:layout_marginEnd="16dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="📷"
                            android:textSize="22sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Scanner de Acesso"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="@color/white" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Ler QR Code — entrada e saída"
                            android:textSize="12sp"
                            android:textColor="#99FFFFFF"
                            android:layout_marginTop="2dp" />

                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="›"
                        android:textSize="26sp"
                        android:textColor="#66FFFFFF" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- IP Config -->
            <TextView
                android:id="@+id/btn_config_ip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⚙ Configurar IP do servidor"
                android:textSize="12sp"
                android:textColor="@color/text_hint"
                android:paddingVertical="8dp"
                android:layout_gravity="center_horizontal" />

        </LinearLayout>
    </ScrollView>

</LinearLayout>
