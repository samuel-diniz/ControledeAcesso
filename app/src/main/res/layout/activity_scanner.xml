<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <com.journeyapps.barcodescanner.DecoratedBarcodeView
        android:id="@+id/barcode_scanner"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Mode selector at top -->
    <LinearLayout
        android:id="@+id/layout_modo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:orientation="vertical"
        android:background="#CC000000"
        android:padding="12dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Modo de Leitura:"
            android:textColor="@color/white"
            android:textSize="13sp"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="8dp" />

        <RadioGroup
            android:id="@+id/rg_modo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_gravity="center_horizontal">

            <RadioButton
                android:id="@+id/rb_entrada"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ENTRADA"
                android:textColor="@color/white"
                android:buttonTint="#4CAF50"
                android:checked="true"
                android:layout_marginEnd="24dp"
                android:textSize="15sp"
                android:textStyle="bold" />

            <RadioButton
                android:id="@+id/rb_saida"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SAIDA"
                android:textColor="@color/white"
                android:buttonTint="#FF9800"
                android:textSize="15sp"
                android:textStyle="bold" />

        </RadioGroup>

    </LinearLayout>

    <!-- Card de resultado sobreposto na parte inferior -->
    <LinearLayout
        android:id="@+id/card_resultado"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:padding="24dp"
        android:visibility="gone"
        android:background="#CC000000">

        <TextView
            android:id="@+id/tv_resultado"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:layout_gravity="center_horizontal" />

        <TextView
            android:id="@+id/tv_participante_nome"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="18sp"
            android:textColor="@color/white"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="4dp" />

        <TextView
            android:id="@+id/tv_mensagem"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:textColor="#CCFFFFFF"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="4dp" />

    </LinearLayout>

</FrameLayout>
