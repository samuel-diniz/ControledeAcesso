<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F5">

    <!-- Seletor de evento -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@android:color/white"
        android:elevation="2dp"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📊 Relatório de Presença"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#212121"
            android:layout_marginBottom="12dp" />

        <Spinner
            android:id="@+id/spinner_evento_relatorio"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btn_gerar_relatorio"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Gerar Relatório"
            android:backgroundTint="#1565C0" />

    </LinearLayout>

    <!-- Cards de estatísticas -->
    <LinearLayout
        android:id="@+id/layout_stats"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone"
        android:background="@android:color/white"
        android:layout_marginTop="8dp"
        android:elevation="2dp"
        android:padding="16dp">

        <!-- Barra de capacidade -->
        <TextView
            android:id="@+id/tv_rel_evento_nome"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#1565C0"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/tv_rel_ocupacao_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:textColor="#757575"
            android:layout_marginBottom="6dp" />

        <ProgressBar
            android:id="@+id/pb_ocupacao"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="14dp"
            android:max="100"
            android:progress="0"
            android:layout_marginBottom="12dp" />

        <!-- 4 cards de stats -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="#E3F2FD"
                android:padding="10dp"
                android:layout_marginEnd="4dp">
                <TextView
                    android:id="@+id/tv_total_aprovados"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="#1565C0" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Confirmados"
                    android:textSize="10sp"
                    android:textColor="#1565C0" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="#E8F5E9"
                android:padding="10dp"
                android:layout_marginEnd="4dp">
                <TextView
                    android:id="@+id/tv_total_dentro"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="#2E7D32" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Dentro"
                    android:textSize="10sp"
                    android:textColor="#2E7D32" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="#FFF8E1"
                android:padding="10dp"
                android:layout_marginEnd="4dp">
                <TextView
                    android:id="@+id/tv_total_saiu"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="#F57F17" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Saíram"
                    android:textSize="10sp"
                    android:textColor="#F57F17" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="#FFEBEE"
                android:padding="10dp">
                <TextView
                    android:id="@+id/tv_total_ausente"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="#C62828" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Ausentes"
                    android:textSize="10sp"
                    android:textColor="#C62828" />
            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

    <!-- Lista de participantes -->
    <LinearLayout
        android:id="@+id/layout_lista"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:visibility="gone"
        android:layout_marginTop="8dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Lista de Participantes"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="#757575"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="8dp"
            android:paddingBottom="4dp" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_relatorio"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="8dp"
            android:clipToPadding="false" />

    </LinearLayout>

    <TextView
        android:id="@+id/tv_sem_dados_relatorio"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Selecione um evento e clique em Gerar Relatório"
        android:textColor="#9E9E9E"
        android:gravity="center"
        android:padding="40dp"
        android:visibility="visible" />

</LinearLayout>
